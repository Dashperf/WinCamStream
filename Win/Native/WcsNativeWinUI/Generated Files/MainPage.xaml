<Page x:ConnectionId='1'
    x:Class="WcsNativeWinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WcsNativeWinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
                     >

    <Page.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FF1C1F24"/>
        <SolidColorBrush x:Key="AmbientShape1Brush" Color="#264A89DC"/>
        <SolidColorBrush x:Key="AmbientShape2Brush" Color="#1F2DBF86"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF202835"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#FF2F3A4E"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF2F6FF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFB8C3D7"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FF131C2A"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#FF35455F"/>
        <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FF25334A"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FF3A4E6E"/>
        <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#FFF2F6FF"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ButtonForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        </Style>
    </Page.Resources>

    <Grid x:ConnectionId='2' x:Name="RootGrid" Background="{StaticResource AppBackgroundBrush}">
        <Grid>
            <Ellipse
                Width="460"
                Height="460"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="-140,-180,0,0"
                Fill="{StaticResource AmbientShape1Brush}"
                Opacity="0.10"/>
            <Ellipse
                Width="520"
                Height="520"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,-240,-180,0"
                Fill="{StaticResource AmbientShape2Brush}"
                Opacity="0.08"/>
        </Grid>

        <Grid x:ConnectionId='3' x:Name="MainContentRoot" Margin="24" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="20">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            Text="WinCamStream"
                            FontSize="34"
                            FontWeight="SemiBold"
                            FontFamily="Segoe UI"/>
                        <TextBlock
                            Text="Open-source smartphone camera stream in Windows project WinCamStream"
                            Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Button x:ConnectionId='42' Content="Aide"               />
                        <ToggleSwitch x:ConnectionId='43'
                            x:Name="ThemeToggle"
                            Header="Theme"
                            MinWidth="160"
                            OffContent="Clair"
                            OnContent="Sombre"
                                                   />
                        <Border x:ConnectionId='44'
                            x:Name="StatusBadgeBorder"
                            VerticalAlignment="Center"
                            CornerRadius="12"
                            Padding="12,8"
                            Background="#FF2D3F5A">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon x:ConnectionId='45'
                                    x:Name="StatusBadgeIcon"
                                    Glyph="&#xE895;"
                                    Foreground="White"/>
                                <TextBlock x:ConnectionId='46'
                                    x:Name="StatusBadgeText"
                                    Text="Initializing"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnSpacing="16" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="16">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Connection" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid ColumnSpacing="12" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Host" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:ConnectionId='39' Grid.Column="1" x:Name="HostBox" Text="127.0.0.1"/>

                                <TextBlock Grid.Column="2" Text="Video" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:ConnectionId='40' Grid.Column="3" x:Name="VideoPortBox" Text="5000"/>

                                <TextBlock Grid.Column="4" Text="Control" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:ConnectionId='41' Grid.Column="5" x:Name="ControlPortBox" Text="5001"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Encoder" Style="{StaticResource SectionTitleStyle}"/>

                            <Grid ColumnSpacing="12" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Resolution" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:ConnectionId='35' Grid.Column="1" x:Name="ResolutionBox" SelectedIndex="1">
                                    <x:String>720p</x:String>
                                    <x:String>1080p</x:String>
                                    <x:String>4k</x:String>
                                </ComboBox>

                                <TextBlock Grid.Column="2" Text="FPS" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:ConnectionId='36' Grid.Column="3" x:Name="FpsBox" Text="120"/>

                                <TextBlock Grid.Column="4" Text="Bitrate" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:ConnectionId='37' Grid.Column="5" x:Name="BitrateBox" Text="35"/>

                                <TextBlock Grid.Column="6" Text="Profile" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:ConnectionId='38' Grid.Column="7" x:Name="ProfileBox" SelectedIndex="2">
                                    <x:String>baseline</x:String>
                                    <x:String>main</x:String>
                                    <x:String>high</x:String>
                                </ComboBox>
                            </Grid>

                            <Grid ColumnSpacing="12" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="105"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="170"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Entropy" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:ConnectionId='30' Grid.Column="1" x:Name="EntropyBox" SelectedIndex="1">
                                    <x:String>cavlc</x:String>
                                    <x:String>cabac</x:String>
                                </ComboBox>

                                <TextBlock Grid.Column="2" Text="Protocol" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:ConnectionId='31' Grid.Column="3" x:Name="ProtocolBox" SelectedIndex="0">
                                    <x:String>annexb</x:String>
                                    <x:String>avcc</x:String>
                                </ComboBox>

                                <TextBlock Grid.Column="4" Text="Orientation" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:ConnectionId='32' Grid.Column="5" x:Name="OrientationBox" SelectedIndex="0">
                                    <x:String>portrait</x:String>
                                    <x:String>landscape_left</x:String>
                                    <x:String>landscape_right</x:String>
                                </ComboBox>

                                <TextBlock Grid.Column="6" Text="Min/Max" Style="{StaticResource FieldLabelStyle}"/>
                                <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="8">
                                    <TextBox x:ConnectionId='33' x:Name="MinBitrateBox" Width="76" Text="6"/>
                                    <TextBox x:ConnectionId='34' x:Name="MaxBitrateBox" Width="76" Text="120"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="18">
                                <ToggleSwitch x:ConnectionId='27' x:Name="IntraOnlyToggle" Header="Intra-only" OffContent="Off" OnContent="On"/>
                                <ToggleSwitch x:ConnectionId='28' x:Name="AutoRotateToggle" Header="Auto-rotate" IsOn="True" OffContent="Off" OnContent="On"/>
                                <ToggleSwitch x:ConnectionId='29' x:Name="AutoBitrateToggle" Header="Auto bitrate" IsOn="True" OffContent="Off" OnContent="On"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Actions" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Button x:ConnectionId='18' Grid.Row="0" Grid.Column="0" Content="Restart iProxy"                         MinHeight="40"/>
                                <Button x:ConnectionId='19' Grid.Row="0" Grid.Column="1" Content="Status"                  MinHeight="40"/>
                                <Button x:ConnectionId='20' Grid.Row="0" Grid.Column="2" Content="Start"                 MinHeight="40"/>
                                <Button x:ConnectionId='21' Grid.Row="0" Grid.Column="3" Content="Stop"                MinHeight="40"/>
                                <Button x:ConnectionId='22' Grid.Row="0" Grid.Column="4" Content="Restart"                   MinHeight="40"/>

                                <Button x:ConnectionId='23' Grid.Row="1" Grid.Column="0" Content="Apply"                 MinHeight="40"/>
                                <Button x:ConnectionId='24' Grid.Row="1" Grid.Column="1" Content="Preview"                   MinHeight="40"/>
                                <Button x:ConnectionId='25' Grid.Row="1" Grid.Column="2" Content="Start VCam"                     MinHeight="40"/>
                                <Button x:ConnectionId='26' Grid.Row="1" Grid.Column="3" Content="Stop VCam"                    MinHeight="40"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Live Status" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock x:ConnectionId='16'
                                x:Name="StatusTextBlock"
                                Text="pending..."
                                TextWrapping="WrapWholeWords"
                                Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Border
                                Background="#264A89DC"
                                Opacity="0.12"
                                CornerRadius="10"
                                Padding="10">
                                <TextBlock x:ConnectionId='17'
                                    x:Name="MetricsTextBlock"
                                    Text="pending..."
                                    TextWrapping="WrapWholeWords"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    FontFamily="Cascadia Mono"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Logs" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBox x:ConnectionId='15'
                                Grid.Row="1"
                                x:Name="LogBox"
                                IsReadOnly="True"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                FontFamily="Cascadia Mono"
                                VerticalAlignment="Stretch"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid x:ConnectionId='4' x:Name="InitOverlay" Visibility="Visible" Background="#FF131821">
            <Grid
                Width="520"
                MaxWidth="520"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="4" Margin="0,10,0,0">
                    <TextBlock Text="WinCamStream" FontSize="42" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock
                        Text="Démarage"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,26,0,26">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="18">
                        <Grid Width="260" Height="260">
                            <Image
                                Width="180"
                                Height="180"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.10"
                                Source="ms-appx:///Assets/WcsLogo.png"/>
                            <ProgressRing x:ConnectionId='13'
                                x:Name="InitProgressRing"
                                Width="220"
                                Height="220"
                                IsActive="True"/>
                            <TextBlock x:ConnectionId='14'
                                x:Name="InitPercentText"
                                Text="0%"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="36"
                                FontWeight="SemiBold"/>
                        </Grid>

                        <ProgressBar x:ConnectionId='6'
                            x:Name="InitProgressBar"
                            Minimum="0"
                            Maximum="100"
                            Value="0"
                            Width="360"
                            Height="8"/>

                        <TextBlock x:ConnectionId='7'
                            x:Name="InitStepText"
                            Text="Ouverture"
                            FontSize="20"
                            FontWeight="SemiBold"
                            TextAlignment="Center"
                            HorizontalAlignment="Center"/>
                        <TextBlock x:ConnectionId='8'
                            x:Name="InitDetailText"
                            Text="Preparation du demarrage."
                            Foreground="{StaticResource TextSecondaryBrush}"
                            TextWrapping="WrapWholeWords"
                            TextAlignment="Center"
                            HorizontalAlignment="Center"
                            MaxWidth="420"/>

                        <Border x:ConnectionId='9'
                            x:Name="InitFailurePanel"
                            Visibility="Collapsed"
                            Background="#332C3A50"
                            BorderBrush="#664A89DC"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14"
                            MaxWidth="430">
                            <StackPanel Spacing="10">
                                <TextBlock x:ConnectionId='10'
                                    x:Name="InitFailureText"
                                    Text="Echec au demarrage."
                                    FontWeight="SemiBold"
                                    Foreground="#FFFFC2C2"
                                    TextWrapping="WrapWholeWords"
                                    TextAlignment="Center"/>
                                <TextBlock x:ConnectionId='11'
                                    x:Name="InitTipsText"
                                    Text="Tip"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    TextWrapping="WrapWholeWords"
                                    TextAlignment="Center"/>
                                <Button x:ConnectionId='12'
                                    x:Name="InitRetryButton"
                                    Content="Reessayer"
                                                       
                                    HorizontalAlignment="Center"
                                    MinWidth="150"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <TextBlock x:ConnectionId='5'
                    Grid.Row="2"
                    x:Name="InitFooterText"
                    Text="WinCamStream v1.0.7 - GPL-3.0 license"
                    HorizontalAlignment="Center"
                    Foreground="#7F9AA8BC"
                    FontSize="12"
                    Margin="0,0,0,10"/>
            </Grid>
        </Grid>
    </Grid>
</Page>

